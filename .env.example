# Path to macOS Photos.sqlite. In Docker, mount the database at this path.
PHOTOS_SQLITE_PATH=/photos-library/Photos.sqlite

# Immich Configuration
# Immich server URL
IMMICH_URL=http://immich-server:2283

# Immich API key (generate from User Settings > API Keys)
IMMICH_API_KEY=your-immich-api-key-here

# Sync Configuration
# Dry run mode (true/false) - when true, only reports what would be done
DRY_RUN=true

# Batch size for Immich API updates
BATCH_SIZE=50

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
